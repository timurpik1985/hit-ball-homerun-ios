name: Build iOS App
on:
  workflow_dispatch:

jobs:
  build-ios:
    runs-on: macos-latest
    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Setup Node 22
        uses: actions/setup-node@v4
        with:
          node-version: 22
          check-latest: true

      - name: Force System to Use Node 22
        run: |
          brew install node@22
          brew link --overwrite node@22
          echo "$(brew --prefix node@22)/bin" >> $GITHUB_PATH

      - name: Install Cordova
        run: npm install -g cordova@latest --force

      - name: Build iOS
        env:
          CORDOVA_TELEMETRY_OPT_OUT: 1
        run: |
          # Manually create the folder so Cordova doesn't ask to create it
          mkdir -p ~/.cordova
          # Add the platform and build
          cordova platform add ios --non-interactive
          cordova build ios --non-interactive
          
      - name: Upload Artifact
        uses: actions/upload-artifact@v4
        with:
          name: ios-app
          path: platforms/ios/build/
