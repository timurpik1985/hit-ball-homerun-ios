<?xml version='1.0' encoding='utf-8'?>
<widget id="com.timurpiker.homerungame" version="1.0.23" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>Hit Ball Homerun Free Play</name>
    <description>The ultimate baseball hitting game! Flick to hit amazing home runs through space. Unlock Silver, Gold &amp; Diamond balls as you journey from the stadium to the cosmos.</description>
    <author email="timurpiker@gmail.com" href="https://github.com/timurpik1985">Timur Piker</author>

    <content src="index.html" />
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />

    <preference name="orientation" value="portrait" />
    <preference name="Fullscreen" value="true" />
    <preference name="DisallowOverscroll" value="true" />
    <preference name="BackupWebStorage" value="none" />

    <platform name="ios">
        <preference name="deployment-target" value="13.0" />
        <preference name="SwiftVersion" value="5.3" />
        <preference name="WKWebViewOnly" value="true" />
        <preference name="CordovaWebViewEngine" value="CDVWKWebView" />

        <preference name="StatusBarOverlaysWebView" value="false" />
        <preference name="StatusBarBackgroundColor" value="#000000" />
        <preference name="StatusBarStyle" value="lightcontent" />
        <preference name="target-device" value="universal" />
        <icon src="res/ios/icon.png" width="1024" height="1024" />
        <icon src="res/ios/icon-20.png" width="20" height="20" />
        <icon src="res/ios/icon-29.png" width="29" height="29" />
        <icon src="res/ios/icon-40.png" width="40" height="40" />
        <icon src="res/ios/icon-50.png" width="50" height="50" />
        <icon src="res/ios/icon-57.png" width="57" height="57" />
        <icon src="res/ios/icon-58.png" width="58" height="58" />
        <icon src="res/ios/icon-60.png" width="60" height="60" />
        <icon src="res/ios/icon-72.png" width="72" height="72" />
        <icon src="res/ios/icon-76.png" width="76" height="76" />
        <icon src="res/ios/icon-80.png" width="80" height="80" />
        <icon src="res/ios/icon-87.png" width="87" height="87" />
        <icon src="res/ios/icon-100.png" width="100" height="100" />
        <icon src="res/ios/icon-114.png" width="114" height="114" />
        <icon src="res/ios/icon-120.png" width="120" height="120" />
        <icon src="res/ios/icon-144.png" width="144" height="144" />
        <icon src="res/ios/icon-152.png" width="152" height="152" />
        <icon src="res/ios/icon-167.png" width="167" height="167" />
        <icon src="res/ios/icon-180.png" width="180" height="180" />

        <edit-config file="*-Info.plist" mode="merge" target="NSAppTransportSecurity">
            <dict>
                <key>NSAllowsArbitraryLoads</key>
                <true/>
            </dict>
        </edit-config>

        <edit-config file="*-Info.plist" mode="merge" target="UIRequiresFullScreen">
            <true/>
        </edit-config>

        <edit-config file="*-Info.plist" mode="merge" target="UISupportedInterfaceOrientations">
            <array>
                <string>UIInterfaceOrientationPortrait</string>
            </array>
        </edit-config>

        <edit-config file="*-Info.plist" mode="merge" target="UISupportedInterfaceOrientations~ipad">
            <array>
                <string>UIInterfaceOrientationPortrait</string>
                <string>UIInterfaceOrientationPortraitUpsideDown</string>
            </array>
        </edit-config>

        <edit-config file="*-Info.plist" mode="merge" target="NSUserTrackingUsageDescription">
            <string>This allows us to show you personalized ads to support the free version of the game.</string>
        </edit-config>

        <!-- Required by Google Mobile Ads SDK. Production AdMob iOS App ID. -->
        <!-- Real App ID already inserted. -->
        <edit-config file="*-Info.plist" mode="merge" target="GADApplicationIdentifier">
            <string>ca-app-pub-1629985022407089~9813154293</string>
        </edit-config>
    </platform>

    <plugin name="cordova-plugin-whitelist" source="npm" />
    <plugin name="cordova-plugin-wkwebview-engine" source="npm" />
    <plugin name="cordova-plugin-statusbar" source="npm" />

    <!-- Required for AdMob rewarded/interstitial ads. Uses real production iOS App ID. -->
    <!-- Real App ID already inserted. -->
    <plugin name="admob-plus-cordova" source="npm">
        <variable name="APP_ID_IOS" value="ca-app-pub-1629985022407089~9813154293" />
    </plugin>
</widget>
