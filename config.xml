name: Build iOS App
on:
  workflow_dispatch:

jobs:
  build-ios:
    runs-on: macos-latest
    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Force Node 22
        uses: actions/setup-node@v4
        with:
          node-version: 22
          # Forces GitHub to ignore any local version-lock files
          check-latest: true 

      - name: Install Cordova
        # --force bypasses the engine warnings so the build continues
        run: npm install -g cordova@latest --force

      - name: Build iOS
        # This is the modern way to disable telemetry without using a command.
        # It prevents the 'Cordova does not know telemetry' crash.
        env:
          CORDOVA_TELEMETRY_OPT_OUT: 1
        run: |
          cordova platform add ios
          cordova build ios
          
      - name: Upload Artifact
        uses: actions/upload-artifact@v4
        with:
          name: ios-app
          path: platforms/ios/build/
