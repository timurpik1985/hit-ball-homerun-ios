name: Build iOS App
on:
  workflow_dispatch:

jobs:
  build-ios:
    runs-on: macos-latest
    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Force Node 22
        uses: actions/setup-node@v4
        with:
          node-version: 22
          # If you have an .nvmrc file in your repo, this ignores it
          check-latest: true 

      - name: Install Cordova
        # The --force flag ensures the install finishes despite engine warnings
        run: npm install -g cordova@latest --force

      - name: Build iOS
        # This ENV block is the modern way to disable telemetry. 
        # It achieves the same thing without crashing the build.
        env:
          CORDOVA_TELEMETRY_OPT_OUT: 1
        run: |
          cordova platform add ios
          cordova build ios
          
      - name: Upload Artifact
        uses: actions/upload-artifact@v4
        with:
          name: ios-app
          path: platforms/ios/build/
