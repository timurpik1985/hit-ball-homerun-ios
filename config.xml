<?xml version='1.0' encoding='utf-8'?>
<widget id="com.timurpiker.hitballhomerun" version="1.0.9" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>Hit Ball Homerun Free Paly</name>
    <description>The ultimate baseball hitting game! Flick to hit amazing home runs through space. Unlock Silver, Gold &amp; Diamond balls as you journey from the stadium to the cosmos.</description>
    <author email="timurpiker@gmail.com" href="https://github.com/timurpik1985">Timur Piker</author>
    
    <content src="index.html" />
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />
    
    <preference name="orientation" value="portrait" />
    <preference name="Fullscreen" value="true" />
    <preference name="DisallowOverscroll" value="true" />
    <preference name="BackupWebStorage" value="none" />
    <preference name="SplashShowOnlyFirstTime" value="false" />
    <preference name="AutoHideSplashScreen" value="true" />
    <preference name="SplashScreenDelay" value="2000" />
    <preference name="FadeSplashScreen" value="true" />
    <preference name="FadeSplashScreenDuration" value="500" />
    
    <platform name="ios">
        <!-- iOS Version Requirements -->
        <preference name="deployment-target" value="13.0" />
        <preference name="WKWebViewOnly" value="true" />
        <preference name="CordovaWebViewEngine" value="CDVWKWebView" />
        
        <!-- UI Preferences -->
        <preference name="StatusBarOverlaysWebView" value="false" />
        <preference name="StatusBarBackgroundColor" value="#000000" />
        <preference name="StatusBarStyle" value="lightcontent" />
        <preference name="HideMobileQuickActionButtonBar" value="true" />
        <preference name="KeyboardDisplayRequiresUserAction" value="false" />
        <preference name="SuppressesIncrementalRendering" value="false" />
        <preference name="TopActivityIndicator" value="gray" />
        
        <!-- iPad Compliance -->
        <preference name="target-device" value="universal" />
        
        <!-- App Icon (single 1024x1024 - Cordova auto-generates all sizes) -->
        <icon src="res/ios/icon.png" />
        
        <!-- Info.plist Customizations -->
        <edit-config file="*-Info.plist" mode="merge" target="NSAppTransportSecurity">
            <dict>
                <key>NSAllowsArbitraryLoads</key>
                <true/>
            </dict>
        </edit-config>
        
        <edit-config file="*-Info.plist" mode="merge" target="UIRequiresFullScreen">
            <true/>
        </edit-config>
        
        <edit-config file="*-Info.plist" mode="merge" target="UIStatusBarHidden">
            <false/>
        </edit-config>
        
        <edit-config file="*-Info.plist" mode="merge" target="UIViewControllerBasedStatusBarAppearance">
            <false/>
        </edit-config>
        
        <edit-config file="*-Info.plist" mode="merge" target="UISupportedInterfaceOrientations">
            <array>
                <string>UIInterfaceOrientationPortrait</string>
            </array>
        </edit-config>
        
        <edit-config file="*-Info.plist" mode="merge" target="UISupportedInterfaceOrientations~ipad">
            <array>
                <string>UIInterfaceOrientationPortrait</string>
                <string>UIInterfaceOrientationPortraitUpsideDown</string>
            </array>
        </edit-config>
        
        <!-- Privacy descriptions (required for App Store) -->
        <edit-config file="*-Info.plist" mode="merge" target="NSUserTrackingUsageDescription">
            <string>This allows us to show you personalized ads to support the free version of the game.</string>
        </edit-config>
    </platform>
    
    <!-- Plugins -->
    <plugin name="cordova-plugin-whitelist" source="npm" />
    <plugin name="cordova-plugin-wkwebview-engine" source="npm" />
    <plugin name="cordova-plugin-statusbar" source="npm" />
    <plugin name="cordova-plugin-splashscreen" source="npm" />
    
</widget>
