<?xml version='1.0' encoding='utf-8'?>
<widget id="com.timurpiker.homerungame" version="1.0.6" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>Hit Ball Homerun</name>
    <description>A simple baseball homerun game.</description>
    <author email="dev@example.com" href="http://example.com">
        Timur Piker
    </author>
    
    <content src="index.html" />
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />

    <platform name="ios">
        <allow-intent href="itms:*" />
        <allow-intent href="itms-apps:*" />
        
        <preference name="UIRequiresFullScreen" value="true" />
        
        <preference name="Orientation" value="portrait" />
        <preference name="UISupportedInterfaceOrientations" value="UIInterfaceOrientationPortrait,UIInterfaceOrientationPortraitUpsideDown" />
        
        <preference name="deployment-target" value="13.0" />
    </platform>

    <preference name="Fullscreen" value="true" />
    <preference name="DisallowOverscroll" value="true" />
</widget>
